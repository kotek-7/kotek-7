---
import "../styles/global.css";
import FontPreloads from "../components/FontPreloads.astro";

interface Props {
  title?: string;
}

const { title = "kotek のホームページ" } = Astro.props;
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const navItems = [
  { href: "/", label: "home" },
  { href: "/about", label: "about" },
  { href: "/activities", label: "activities" },
  { href: "/posts", label: "posts" },
];

const isCurrentPage = (href: string) =>
  href === "/" ? pathname === href : pathname === href || pathname.startsWith(`${href}/`);
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <FontPreloads />
  </head>
  <body>
    <div class="mx-auto min-h-screen max-w-5xl px-4 sm:px-10 lg:px-16">
      <slot />
    </div>
    <nav class="fixed bottom-0 left-0 right-0 z-10 bg-background">
      <div
        class="mx-auto flex max-w-5xl items-center justify-between gap-0 md:gap-10 px-4 py-4 sm:px-10 lg:px-16"
      >
        {navItems.map(({ href, label }) => {
          const isCurrent = isCurrentPage(href);

          return (
            <a
              href={href}
              aria-current={isCurrent ? "page" : undefined}
              class:list={[
                "w-fit border-t-2 px-2 py-2 font-heading text-sm uppercase tracking-[0.18em] sm:px-5 sm:text-xl",
                isCurrent
                  ? "border-accent text-accent"
                  : "border-transparent text-primary hover:border-primary/35",
              ]}
            >
              {label}
            </a>
          );
        })}
      </div>
    </nav>
  </body>
</html>
