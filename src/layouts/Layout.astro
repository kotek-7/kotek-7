---
import "../styles/global.css";
import FontPreloads from "../components/FontPreloads.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "kotek のホームページ",
  description = "kotek のホームページです。",
} = Astro.props;
const href = Astro.url.href;
const ogImageUrl = new URL("/og-image.png", Astro.url);
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const navItems = [
  { href: "/", label: "home" },
  { href: "/about", label: "about" },
  { href: "/activities", label: "activities" },
  { href: "/posts", label: "posts" },
];

const isCurrentPage = (href: string) =>
  href === "/"
    ? pathname === href
    : pathname === href || pathname.startsWith(`${href}/`);
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={href} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={href} />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="kotek のイラスト" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.href} />
    <FontPreloads />
  </head>
  <body>
    <div class="mx-auto min-h-screen max-w-5xl px-4 sm:px-10 lg:px-16">
      <slot />
    </div>
    <nav class="fixed bottom-0 left-0 right-0 z-10 bg-background">
      <div
        class="mx-auto flex max-w-5xl items-center justify-between gap-0 md:gap-10 px-4 py-4 sm:px-10 lg:px-16"
      >
        {
          navItems.map(({ href, label }) => {
            const isCurrent = isCurrentPage(href);

            return (
              <a
                href={href}
                aria-current={isCurrent ? "page" : undefined}
                class:list={[
                  "w-fit border-t-2 px-2 py-2 font-heading text-sm uppercase tracking-[0.18em] sm:px-5 sm:text-xl",
                  isCurrent
                    ? "border-accent text-accent"
                    : "border-transparent text-primary hover:border-primary/35",
                ]}
              >
                {label}
              </a>
            );
          })
        }
      </div>
    </nav>
  </body>
</html>
