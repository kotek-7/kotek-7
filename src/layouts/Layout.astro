---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "kotek のホームページ" } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Jost:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@400"
    />
  </head>
  <body>
    <div class="mx-auto min-h-screen max-w-5xl px-4 sm:px-10 lg:px-16">
      <slot />
    </div>
    <nav class="fixed bottom-0 left-0 right-0 z-10 bg-background">
      <div
        class="mx-auto flex max-w-5xl items-center justify-between gap-2 md:gap-10 px-4 py-4 sm:px-10 lg:px-16"
      >
        <a
          href="/"
          class="w-fit border-t-2 border-transparent px-2 md:px-5 py-2 font-heading text-sm md:text-xl uppercase tracking-[0.18em] text-primary hover:border-primary/35 no-underline"
        >
          home
        </a>
        <a
          href="/about"
          class="w-fit border-t-2 border-transparent px-2 md:px-5 py-2 font-heading text-sm md:text-xl uppercase tracking-[0.18em] text-primary hover:border-primary/35 no-underline"
        >
          about
        </a>
        <a
          href="/activities"
          class="w-fit border-t-2 border-transparent px-2 md:px-5 py-2 font-heading text-sm md:text-xl uppercase tracking-[0.18em] text-primary hover:border-primary/35 no-underline"
        >
          activities
        </a>
        <a
          href="/posts"
          class="w-fit border-t-2 border-transparent px-2 md:px-5 py-2 font-heading text-sm md:text-xl uppercase tracking-[0.18em] text-primary hover:border-primary/35 no-underline"
        >
          posts
        </a>
      </div>
    </nav>
  </body>
</html>
